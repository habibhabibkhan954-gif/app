{
  "expo": {
    "name": "Sausico",
    "slug": "sausico",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sausico",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/android-icon-monochrome.png",
      "color": "#ffffff"
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "sausico.pages.dev"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.saavnlabs.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "publicPath": "/"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#000000",
          "barStyle": "dark",
          "borderColor": "#000000",
          "visibility": "visible",
          "behavior": "inset-swipe",
          "position": "relative"
        }
      ],
      "expo-speech-recognition",
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "1aa6c79f-c4cd-498d-8de2-8a14dd1fe7a9"
      }
    },
    "ios": {
      "bundleIdentifier": "com.saavnlabs.app"
    }
  }
}
